# Security
SECRET_KEY=replace-with-a-secure-random-string
DEBUG=False

# Hosts
# Note: For PythonAnywhere, add your username: yourusername.pythonanywhere.com
ALLOWED_HOSTS=127.0.0.1,localhost,yourusername.pythonanywhere.com

# Production security. Use False only for local HTTP development.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional local AI assistant through Ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
